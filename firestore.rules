rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is a GC
    function isGC() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'gc';
    }

    // Helper: get the GC's school
    function gcSchool() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
    }

    // Users collection: each user can only read/write their own doc
    match /users/{userId} {
      // Self-read OR same-school read (merged so school-query works)
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || (resource.data.school != null
                          && resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school));
      allow create: if request.auth != null && request.auth.uid == userId
                   && !('isAdmin' in request.resource.data)
                   && !('role' in request.resource.data)
                   && request.resource.data.name is string
                   && request.resource.data.name.size() <= 50
                   && request.resource.data.avatar is string
                   && request.resource.data.avatar.size() <= 100
                   && (!('school' in request.resource.data) || (request.resource.data.school is string && request.resource.data.school.size() <= 50));
      allow update: if request.auth != null && request.auth.uid == userId
                   && !('isAdmin' in request.resource.data)
                   && request.resource.data.role == resource.data.role
                   && request.resource.data.school == resource.data.school
                   && request.resource.data.name is string
                   && request.resource.data.name.size() <= 50
                   && request.resource.data.avatar is string
                   && request.resource.data.avatar.size() <= 100;
      // Admin can read all user docs + delete students (for AdminDashboard)
      allow read, delete: if request.auth != null
                  && request.auth.token.email == 'admin@nextstep.app';
      // GC can read + delete user docs where school matches their own school
      allow read, delete: if request.auth != null
                  && isGC()
                  && resource.data.school == gcSchool();
    }

    // Progress collection: self read + validated writes
    match /progress/{userId} {
      // Self-read
      allow read: if request.auth != null && request.auth.uid == userId;
      // Admin can read + delete all progress docs (for AdminDashboard)
      allow read, delete: if request.auth != null
                  && request.auth.token.email == 'admin@nextstep.app';
      // GC can read + delete progress docs for students in their school
      allow read, delete: if request.auth != null
                  && isGC()
                  && get(/databases/$(database)/documents/users/$(userId)).data.school == gcSchool();
      // Remediation 2026-04-29 (DPIA risk R1): the previous same-school
      // "Peer Islands" peer-read rule on /progress/{userId} was removed.
      // Read access is now restricted to: self, admin, GC of same school.
      // See compliance/REMEDIATION_LOG.md.

      // Create: self only, cap initial points
      allow create: if request.auth != null && request.auth.uid == userId
                   && (!('pointsData' in request.resource.data)
                       || request.resource.data.pointsData.totalEarned <= 1000);

      // Update: self + field validation on critical gamification fields
      allow update: if request.auth != null && request.auth.uid == userId
        // Points earned can only increase, max +1000 per write
        && (!('pointsData' in resource.data)
            || !('totalEarned' in resource.data.pointsData)
            || (request.resource.data.pointsData.totalEarned >= resource.data.pointsData.totalEarned
                && request.resource.data.pointsData.totalEarned <= resource.data.pointsData.totalEarned + 1000))
        // Points spent can only increase (no refunds)
        && (!('pointsData' in resource.data)
            || !('totalSpent' in resource.data.pointsData)
            || request.resource.data.pointsData.totalSpent >= resource.data.pointsData.totalSpent)
        // Achievements can only be appended, never removed
        && (!('gamification' in resource.data)
            || !('unlockedAchievements' in resource.data.gamification)
            || request.resource.data.gamification.unlockedAchievements
                 .hasAll(resource.data.gamification.unlockedAchievements));
    }

    // Settings collection: each user can only read/write their own doc
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Responses collection: each user can only read/write their own doc
    match /responses/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // GC Notes: GCs can read/write notes for their own school
    match /gcNotes/{schoolId}/students/{studentId} {
      allow read, write: if request.auth != null
                         && isGC()
                         && schoolId == gcSchool();
    }

    // GC Settings: GCs can read/write settings for their own school (dismissed alerts etc.)
    match /gcSettings/{schoolId} {
      allow read, write: if request.auth != null
                         && isGC()
                         && schoolId == gcSchool();
    }

    // Notifications: self read/write + GC read/write for same-school students
    match /notifications/{userId} {
      // Any user can read/write their own notifications (mark read, auto-notifications)
      allow read, create, update: if request.auth != null && request.auth.uid == userId;

      // GCs can read/write notifications for students in their school
      // (read needed because addNotification uses runTransaction with txn.get)
      allow read, create, update: if request.auth != null
                   && isGC()
                   && get(/databases/$(database)/documents/users/$(userId)).data.school == gcSchool();
    }

    // Kudos collection: peer encouragement notes
    match /kudos/{kudosId} {
      // Recipient can read kudos sent to them
      allow read: if request.auth != null
                  && resource.data.toUid == request.auth.uid;
      // Sender can read kudos they sent (for daily limit check)
      allow read: if request.auth != null
                  && resource.data.fromUid == request.auth.uid;
      // Can create if: authed, fromUid is self, toUid != self, same school
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid != request.auth.uid
                    && request.resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
      allow update, delete: if false;
    }

    // Gifts collection: peer island gifts
    match /gifts/{giftId} {
      // Recipient can read their gifts
      allow read: if request.auth != null
                  && resource.data.toUid == request.auth.uid;
      // Sender can read gifts they sent (for daily limit check)
      allow read: if request.auth != null
                  && resource.data.fromUid == request.auth.uid;
      // Can create if: authed, fromUid is self, toUid != self, same school
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid != request.auth.uid
                    && request.resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
      // Recipient can update status from pending to placed
      allow update: if request.auth != null
                    && resource.data.toUid == request.auth.uid
                    && resource.data.status == 'pending'
                    && request.resource.data.status == 'placed';
      allow delete: if false;
    }

    // Teach-backs collection: anonymous peer explanations
    match /teachbacks/{teachbackId} {
      // Same-school students can read teach-backs
      allow read: if request.auth != null
                  && resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
      // Can create if: authed, authorUid is self, school matches own school
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school
                    && request.resource.data.explanation is string
                    && request.resource.data.explanation.size() <= 500;
      // Same-school students can update helpfulCount only (increment by 1, no other fields change)
      allow update: if request.auth != null
                    && resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school
                    && request.resource.data.authorUid == resource.data.authorUid
                    && request.resource.data.school == resource.data.school
                    && request.resource.data.subject == resource.data.subject
                    && request.resource.data.explanation == resource.data.explanation
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.helpfulCount == resource.data.helpfulCount + 1;
      allow delete: if false;
    }

    // Flares collection: anonymous peer help (SOS Flares)
    match /flares/{flareId} {
      // Same-school students can read flares
      allow read: if request.auth != null
                  && resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
      // Can create: authed, senderUid is self, school matches own school
      allow create: if request.auth != null
                    && request.resource.data.senderUid == request.auth.uid
                    && request.resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school
                    && request.resource.data.question is string
                    && request.resource.data.question.size() <= 500;
      // Sender can resolve their own flare (only status field changes)
      allow update: if request.auth != null
                    && resource.data.senderUid == request.auth.uid
                    && request.resource.data.status == 'resolved'
                    && request.resource.data.senderUid == resource.data.senderUid
                    && request.resource.data.school == resource.data.school
                    && request.resource.data.question == resource.data.question
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.expiresAt == resource.data.expiresAt;
      // Same-school peers can increment responseCount (pinned to +1, matching teachbacks pattern)
      allow update: if request.auth != null
                    && resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school
                    && resource.data.senderUid != request.auth.uid
                    && request.resource.data.responseCount == resource.data.responseCount + 1
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.senderUid == resource.data.senderUid
                    && request.resource.data.school == resource.data.school
                    && request.resource.data.question == resource.data.question
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.expiresAt == resource.data.expiresAt;
      allow delete: if false;

      // Flare responses subcollection
      match /responses/{responseId} {
        // Same-school students can read responses (check parent flare's school)
        allow read: if request.auth != null
                    && get(/databases/$(database)/documents/flares/$(flareId)).data.school
                       == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
        // Can create: authed, responderUid is self
        allow create: if request.auth != null
                      && request.resource.data.responderUid == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 1000;
        // Flare sender can mark helpful (only helpful field changes to true)
        allow update: if request.auth != null
                      && get(/databases/$(database)/documents/flares/$(flareId)).data.senderUid == request.auth.uid
                      && request.resource.data.helpful == true
                      && request.resource.data.text == resource.data.text
                      && request.resource.data.responderUid == resource.data.responderUid
                      && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if false;
      }
    }

    // GC Events: key dates added by guidance counsellors per school
    match /gcEvents/{schoolId} {
      // GCs can read/write events for their own school
      allow read, write: if request.auth != null
                         && isGC()
                         && schoolId == gcSchool();
      // Students can read their school's events (for timetable integration)
      allow read: if request.auth != null
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school == schoolId;
    }

    // Island Public: minimal public projection of a student's island
    // (rebuilt 2026-04-29 to replace the same-school read on /progress
    // that was the original R1 exposure — see
    // compliance/PEER_ISLAND_REFACTOR_PLAN.md).
    // Same-school students may read; only Cloud Functions write
    // (Admin SDK bypasses Firestore rules).
    //
    // Rule compares resource.data.school (the queried projection doc's
    // own school field) against the requester's school via a single
    // get() on /users. This shape is required for Firestore queries:
    // a rule that depends on get() of the *target* /users doc cannot
    // be verified against the query's potential result set, so the
    // query is denied even when individual docs would be readable.
    match /islandPublic/{uid} {
      allow read: if request.auth != null
                  && resource.data.school
                     == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
      allow write: if false;
    }

    // Default deny — no other collections are accessible
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
