rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is a GC
    function isGC() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'gc';
    }

    // Helper: get the GC's school
    function gcSchool() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
    }

    // Users collection: each user can only read/write their own doc
    match /users/{userId} {
      // Self-read OR same-school read (merged so school-query works)
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || (resource.data.school != null
                          && resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school));
      allow write: if request.auth != null && request.auth.uid == userId
                   && !('isAdmin' in request.resource.data);
      // Admin can read all user docs + delete students (for AdminDashboard)
      allow read, delete: if request.auth != null
                  && request.auth.token.email == 'admin@nextstep.app';
      // GC can read + delete user docs where school matches their own school
      allow read, delete: if request.auth != null
                  && isGC()
                  && resource.data.school == gcSchool();
    }

    // Progress collection: each user can only read/write their own doc
    match /progress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin can read + delete all progress docs (for AdminDashboard)
      allow read, delete: if request.auth != null
                  && request.auth.token.email == 'admin@nextstep.app';
      // GC can read + delete progress docs for students in their school
      allow read, delete: if request.auth != null
                  && isGC()
                  && get(/databases/$(database)/documents/users/$(userId)).data.school == gcSchool();
      // Peer Islands: students can read progress of same-school peers
      allow read: if request.auth != null
                  && request.auth.uid != userId
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school
                     == get(/databases/$(database)/documents/users/$(userId)).data.school;
    }

    // Settings collection: each user can only read/write their own doc
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Streaks collection: each user can only read/write their own doc
    match /streaks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Moods collection: each user can only read/write their own doc
    match /moods/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin can delete mood docs
      allow delete: if request.auth != null
                  && request.auth.token.email == 'admin@nextstep.app';
      // GC can read + delete mood docs for students in their school
      allow read, delete: if request.auth != null
                  && isGC()
                  && get(/databases/$(database)/documents/users/$(userId)).data.school == gcSchool();
    }

    // Responses collection: each user can only read/write their own doc
    match /responses/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // GC Notes: GCs can read/write notes for their own school
    match /gcNotes/{schoolId}/students/{studentId} {
      allow read, write: if request.auth != null
                         && isGC()
                         && schoolId == gcSchool();
    }

    // GC Settings: GCs can read/write settings for their own school (dismissed alerts etc.)
    match /gcSettings/{schoolId} {
      allow read, write: if request.auth != null
                         && isGC()
                         && schoolId == gcSchool();
    }

    // Kudos collection: peer encouragement notes
    match /kudos/{kudosId} {
      // Recipient can read kudos sent to them
      allow read: if request.auth != null
                  && resource.data.toUid == request.auth.uid;
      // Sender can read kudos they sent (for daily limit check)
      allow read: if request.auth != null
                  && resource.data.fromUid == request.auth.uid;
      // Can create if: authed, fromUid is self, toUid != self, same school
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid != request.auth.uid
                    && request.resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
      allow update, delete: if false;
    }

    // Gifts collection: peer island gifts
    match /gifts/{giftId} {
      // Recipient can read their gifts
      allow read: if request.auth != null
                  && resource.data.toUid == request.auth.uid;
      // Sender can read gifts they sent (for daily limit check)
      allow read: if request.auth != null
                  && resource.data.fromUid == request.auth.uid;
      // Can create if: authed, fromUid is self, toUid != self, same school
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid != request.auth.uid
                    && request.resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
      // Recipient can update status from pending to placed
      allow update: if request.auth != null
                    && resource.data.toUid == request.auth.uid
                    && resource.data.status == 'pending'
                    && request.resource.data.status == 'placed';
      allow delete: if false;
    }

    // Teach-backs collection: anonymous peer explanations
    match /teachbacks/{teachbackId} {
      // Same-school students can read teach-backs
      allow read: if request.auth != null
                  && resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
      // Can create if: authed, authorUid is self, school matches own school
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school;
      // Same-school students can update helpfulCount only (no other fields change)
      allow update: if request.auth != null
                    && resource.data.school == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.school
                    && request.resource.data.authorUid == resource.data.authorUid
                    && request.resource.data.school == resource.data.school
                    && request.resource.data.subject == resource.data.subject
                    && request.resource.data.explanation == resource.data.explanation
                    && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    // Default deny — no other collections are accessible
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
