rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: each user can only read/write their own doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && !('isAdmin' in request.resource.data);
      // Admin can read all user docs (for AdminDashboard)
      allow read: if request.auth != null
                  && request.auth.token.email == 'admin@nextstep.app';
    }

    // Progress collection: each user can only read/write their own doc
    match /progress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin can read all progress docs (for AdminDashboard)
      allow read: if request.auth != null
                  && request.auth.token.email == 'admin@nextstep.app';
    }

    // Default deny — no other collections are accessible
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
